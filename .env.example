# Variables de entorno para PosPunto
# Copia este archivo a .env y completa con tus valores reales.
# .env NO se sube a Git (ya está en .gitignore).
#
# En Vercel: estas variables se configuran en el dashboard del proyecto
# (Settings → Environment Variables) en lugar de un archivo .env.

# URL de tu proyecto Supabase
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Clave anon (pública) de Supabase
# La encuentras en Project Settings → API → Project API keys → anon public
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJI...tu-anon-key...

# Identificador del tenant (negocio) — si tienes un solo negocio, déjalo en 'default'
VITE_TENANT_ID=default
